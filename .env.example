# BF Suma Nexus - Environment Variables Template
# Copy this file to .env.local and fill in your values

# ===========================================
# SUPABASE CONFIGURATION (Required)
# ===========================================
# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous key (public, safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# AUTHENTICATION (Optional - for advanced config)
# ===========================================
# URL for email confirmation redirects
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# ===========================================
# ANALYTICS & TRACKING (Optional)
# ===========================================
# Google Analytics Measurement ID (if using GA)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ===========================================
# API CONFIGURATION (Optional)
# ===========================================
# External API endpoints if needed
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# ===========================================
# BUILD CONFIGURATION (Do not modify)
# ===========================================
# These are set by Vercel automatically
NODE_ENV=development
