# ===========================================
# SITE URL (Required for auth redirects)
# ===========================================
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# ===========================================
# STRIPE CONFIGURATION (Required for billing)
# ===========================================
# Stripe secret key (NEVER expose to client)
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key

# Stripe webhook signing secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs (from Stripe Dashboard → Products)
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_your-pro-price-id
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=price_your-enterprise-price-id

# ===========================================
# ANALYTICS (Optional)
# ===========================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===========================================
# BUILD CONFIGURATION (Set by Vercel automatically)
# ===========================================
NODE_ENV=development
